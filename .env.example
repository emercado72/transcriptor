# ============================================
# Transcriptor - Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================

# --- Node ---
NODE_ENV=development
PORT=3000

# --- PostgreSQL ---
DATABASE_URL=postgresql://localhost:5432/transcriptor
DATABASE_SSL=false

# --- Redis ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# --- OpenRouter (LLM for redaction & review) ---
OPENROUTER_API_KEY=
# Default model for all agents (fallback when per-agent model is not set)
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# Per-agent model overrides — set to test cost-effective alternatives
# Options: anthropic/claude-sonnet-4.6, google/gemini-3-flash-preview,
#          deepseek/deepseek-v3.2, qwen/qwen3.5-plus-02-15
LINA_MODEL=
GLORIA_MODEL=

# --- Groq API (LLM for agent chat) ---
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# --- OpenAI API ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- ElevenLabs Scribe API ---
ELEVENLABS_API_KEY=el_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Google Drive API ---
GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
GOOGLE_DRIVE_ROOT_FOLDER_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Tecnoreuniones Backend ---
TECNOREUNIONES_API_URL=https://www.tecnoreuniones.com/tecnor2.php
TECNOREUNIONES_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Logging ---
LOG_LEVEL=debug

# --- Gloria Review UI ---
GLORIA_PORT=3001

# --- Local Transcription (audio-transcriber) ---
# Set to "local" for Faster-Whisper+Pyannote, "elevenlabs" for cloud Scribe API
TRANSCRIPTION_PROVIDER=elevenlabs

# Path to audio-transcriber project (defaults to ../audio-transcriber)
AUDIO_TRANSCRIBER_PATH=

# Python command
PYTHON_COMMAND=python3

# Whisper model: tiny, base, small, medium, large-v3
LOCAL_WHISPER_MODEL=medium

# Device: cpu or cuda
LOCAL_WHISPER_DEVICE=cpu

# Speaker hints (optional)
# LOCAL_MIN_SPEAKERS=
# LOCAL_MAX_SPEAKERS=

# Hugging Face token (required for Pyannote diarization in local mode)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
